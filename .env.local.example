# Copy this file to .env.local and fill in values from your Supabase project
# (Project Settings → API). The anon key is safe to expose in the browser;
# Row Level Security (supabase/schema.sql) is what protects the data.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# That's it — there are no server-only secrets. Couples log in with Supabase
# Auth, and every read is scoped to them by Row Level Security, so no
# service-role key or shared dashboard password is needed.
#
# In the Supabase dashboard: Authentication → Providers → enable "Email".
# For local development, turn OFF "Confirm email" so signup logs you in
# immediately instead of waiting on a confirmation email.
